{
  "code": "def evaluation_machine_model(\n    data: pd.DataFrame,\n    parameters: dict[str, Any],\n    Scaler: Any,\n    Scaler_baseline: Any,\n    model: Any,\n    model_new: Any,\n    model_baseline: Any,\n) -> [dict[str, Any], dict[str, Any], dict[str, Any]]:\n    \"\"\"Get new data from the machine, load the pre-trained model,\n        scale the data and predict y.\n\n    Args:\n        data: Data containing features and target.\n        Scaler: Scaler for model.\n        Scaler: Scaler for Baseline.\n        model: Pre-trained model.\n        model_new: New-trained model.\n        model_baseline: Baseline model.\n        parameters: Parameters defined in parameters.yml.\n    Returns:\n        evaluation_dict\n        evaluation_dict_new_train\n        evaluation_dict_baseline\n    \"\"\"\n    # get logger for reporting\n    logger = logging.getLogger(__name__)\n\n    # drop all missing values\n    # TODO: add parameter to handle this different\n    data = data.dropna()\n\n    # get time data\n    timestamp = pd.to_datetime(\n        data[parameters[\"time_column\"]], format=\"%Y-%m-%dT%H:%M:%S.%fZ\"\n    )\n\n    # drop columns\n    data = data.drop(columns=parameters[\"drop_columns\"])\n\n    # add time information\n    data[\"hour\"] = timestamp.apply(lambda x: x.hour)\n    data[\"minute\"] = timestamp.apply(lambda x: x.minute)\n    data[\"weekday\"] = timestamp.apply(lambda x: x.weekday())\n\n    # get the X and y from the data frame\n    y_baseline = data[parameters[\"target_column_baseline\"]].astype(float)\n    X_baseline = data.drop(columns=parameters[\"target_column_baseline\"]).astype(float)\n    y_test = data[parameters[\"target_column\"]].astype(float)\n    X = data.drop(columns=parameters[\"target_column\"]).astype(float)\n\n    # scale data\n    X = pd.DataFrame(Scaler.transform(X), columns=X.columns)\n    X_baseline = pd.DataFrame(\n        Scaler_baseline.transform(X_baseline), columns=X_baseline.columns\n    )\n\n    # predicte\n    results_list = []\n    data_list = [[X, y_test], [X, y_test], [X_baseline, y_baseline]]\n    name_list = [\"Pre-Train\", \"New-Train\", \"Baseline\"]\n    model_list = [model, model_new, model_baseline]\n    target_list = [\n        parameters[\"target_column\"],\n        parameters[\"target_column\"],\n        parameters[\"target_column_baseline\"],\n    ]\n    for cur_data, name, clf, target in zip(data_list, name_list, model_list, target_list):\n        X = cur_data[0]\n        y_test = cur_data[1]\n\n        y_pred = clf.predict(X)\n\n        # log results for target values\n        results = {}\n        for v in target:\n            idx = y_test.columns.to_list().index(v)\n\n            # calculate R2 / MAE score of the model\n            r2 = r2_score(y_test[v], y_pred[:, idx])\n            mae = mean_absolute_error(y_test[v], y_pred[:, idx])\n\n            logger.info(\n                \"{} Model has R2 score of {} on data from last training {} until 2h {}.\".format(\n                    name, r2, \"TODO: add time\", v\n                )\n            )\n            logger.info(\n                \"{} Model has MAE score of {} on data from last training {} until 2h {}.\".format(\n                    name, mae, \"TODO: add time\", v\n                )\n            )\n\n            results[v] = {\n                \"y_test\": y_test[v].values.tolist(),\n                \"y_pred\": y_pred[:, idx].tolist(),\n                \"r2\": r2,\n                \"mae\": mae,\n            }\n\n        results_list.append(results)\n\n    return results_list[0], results_list[1], results_list[2]\n",
