  "code": "def predict_next_30min(\n    X_sensor: pd.DataFrame,\n    y_emissions: pd.DataFrame,\n    parameters: dict[str, Any],\n) -> pd.DataFrame:\n    \"\"\"\n    Train an RNN forecaster and predict the next horizon.\n    \"\"\"\n    logger = logging.getLogger(__name__)\n\n    tf.keras.utils.set_random_seed(int(parameters.get(\"random_state\", 42)))\n\n    freq = parameters[\"freq\"]\n    horizon_minutes = int(parameters[\"horizon_minutes\"])\n    seq_len = int(parameters.get(\"seq_len\", 64))\n\n    X_sensor, y_emissions, X, y = _validate_and_align_inputs(X_sensor, y_emissions)\n\n    X_train_df, y_train_df, horizon_steps = _prepare_supervised_training_data(\n        X=X,\n        y=y,\n        freq=freq,\n        horizon_minutes=horizon_minutes,\n        seq_len=seq_len,\n    )\n\n    model = _build_rnn_model(parameters)\n\n    logger.info(\"Start fitting model.\")\n    model.fit(X_train_df, y_train_df)\n\n    logger.info(\"Start forecasting.\")\n    y_forecast = _forecast_horizon_dataframe(\n        model=model,\n        X_sensor=X_sensor,\n        y_emissions=y_emissions,\n        freq=freq,\n        horizon_steps=horizon_steps,\n    )\n\n    logger.info(\"Start explanation/report generation.\")\n    top10_df = _build_top_feature_table(\n        model=model,\n        X_train_df=X_train_df,\n        X_sensor=X_sensor,\n        parameters=parameters,\n    )\n    _create_forecast_report(y_forecast, top10_df, parameters)\n\n    y_forecast[\"ts\"] = y_forecast.index\n    return y_forecast\n",
