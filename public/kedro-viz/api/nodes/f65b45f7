  "code": "def clean_data(data: pd.DataFrame, parameters: dict[str, Any]) -> pd.DataFrame:\n    \"\"\"Clean the data for NOx.\n\n    Args:\n        data: Data containing features and target.\n        parameters: Parameters defined in parameters.yml.\n    Returns:\n        pandas data frame.\n    \"\"\"\n\n    # drop all missing values\n    # TODO: add parameter to handle this different\n    data = data.dropna()\n\n    # get time data\n    timestamp = pd.to_datetime(\n        data[parameters[\"time_column\"]], format=\"%Y-%m-%dT%H:%M:%S.%fZ\"\n    )\n\n    # drop columns\n    data = data.drop(columns=parameters[\"drop_columns\"])\n\n    # add time information\n    data[\"hour\"] = timestamp.apply(lambda x: x.hour)\n    data[\"minute\"] = timestamp.apply(lambda x: x.minute)\n    data[\"weekday\"] = timestamp.apply(lambda x: x.weekday())\n\n    return data\n",
