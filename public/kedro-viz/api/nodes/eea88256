  "code": "def set_timescaledb_data(actions: dict[str, Any], parameters: dict[str, Any]) -> None:\n    def flush(rows_buf):\n        if not rows_buf:\n            return 0\n        # Upsert on (ts, machine, metric); keep existing prediction if new is NULL\n        sql = \"\"\"\n            INSERT INTO measurements (ts, machine, source, metric, value, prediction)\n            VALUES %s\n            ON CONFLICT (ts, machine, metric) DO UPDATE\n            SET value = EXCLUDED.value,\n                prediction = COALESCE(EXCLUDED.prediction, measurements.prediction)\n            \"\"\"\n        execute_values(cur, sql, rows_buf, page_size=10000)\n        conn.commit()\n        n = len(rows_buf)\n        rows_buf.clear()\n        return n\n\n    conn = psycopg2.connect(\n        host=parameters[\"timescaledb\"][\"host\"],\n        port=parameters[\"timescaledb\"].get(\"port\", 5432),\n        user=parameters[\"timescaledb\"][\"user\"],\n        password=parameters[\"timescaledb\"][\"password\"],\n        dbname=parameters[\"timescaledb\"][\"database\"],\n    )\n\n    cur = conn.cursor()\n    rows = []\n    for key, value in actions.items():\n        # settings\n        src = \"kedro\"\n        mach = parameters[\"timescaledb\"][\"machine\"]\n        pred = True\n        ts = (\n            datetime.datetime.now(datetime.timezone.utc)\n            .replace(microsecond=0)\n            .isoformat()\n            .replace(\"+00:00\", \"Z\")\n        )\n        # ts = ts.astimezone(pytz.timezone('Europe/Berlin')).replace(microsecond=0).isoformat().replace(\"+00:00\", \"Z\")\n        metric = key\n        val = value[\"new\"]\n        # Only store finite numbers\n        try:\n            fval = float(val)\n            if not math.isfinite(fval):\n                continue\n        except (TypeError, ValueError):\n            continue\n        rows.append((ts, mach, src, metric, fval, pred))\n    flush(rows)\n    cur.close()\n    conn.close()\n",
