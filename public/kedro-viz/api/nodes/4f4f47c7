{
  "code": "def report_model_performance(\n    model: Any,\n    X_train: pd.DataFrame,\n    y_pred: pd.DataFrame,\n    y_test: pd.Series,\n    parameters: dict[str, Any],\n    guess: dict[str, Any],\n    Scaler: Any,\n):\n    \"\"\"Calculates and logs performance measurments of the model.\n\n    Args:\n        y_pred: Predicted target.\n        y_test: True target.\n    Returns:\n        -\n    \"\"\"\n    # get logger for reporting\n    logger = logging.getLogger(__name__)\n\n    # TODO: store this somehow as numpy array\n    # so we safe the conversion\n    y_pred = y_pred.to_numpy()\n\n    # plot the results\n    for v in parameters[\"target_column\"]:\n        idx = y_test.columns.to_list().index(v)\n        if parameters[\"plotting\"]:\n            fig = plt.figure()\n            plt.scatter(y_test[v], y_pred[:, idx], alpha=0.3)\n            plt.xlabel(\"True Values\")\n            plt.ylabel(\"Predictions\")\n            plt.title(f\"Random Forest Regression {v}\")\n            single_plot_writer = MatplotlibDataset(\n                filepath=f\"output/reporting/{date.today()}/true_vs_pred_{v}.png\"\n            )\n            plt.close()\n            single_plot_writer.save(fig)\n            logger.info(f\"Saved true_vs_pred_{v}.png.\")\n\n        # calculate R2 score of the model\n        r2 = r2_score(y_test[v], y_pred[:, idx])\n        logger.info(f\"Model has R2 score of {r2} on test data for {v}.\")\n\n    # create 2d histo of all unique combinations\n    if parameters[\"plotting\"]:\n        target_idx = y_test.columns.to_list().index(\n            parameters[\"optimization_target\"][0]\n        )\n        for combination in itertools.combinations(parameters[\"2dMap\"], 2):\n            v0_idx = X_train.columns.to_list().index(combination[0])\n            v1_idx = X_train.columns.to_list().index(combination[1])\n\n            # TODO: we again need the constrains for the values here, for now we take the min max of the dataset\n            v0_max = X_train[combination[0]].max()\n            v0_min = 0  # X_train[combination[0]].min()\n            v1_max = X_train[combination[1]].max()\n            v1_min = 0  # X_train[combination[1]].min()\n            x = []\n            y = []\n            z = []\n            cur_guess = copy.deepcopy(\n                Scaler.inverse_transform(guess[\"values\"].reshape(1, -1))[0]\n            )\n            # we do 100 steps\n            for cur_v0 in np.arange(\n                v0_min, v0_max, (v0_max - v0_min) / 100, dtype=float\n            ):\n                for cur_v1 in np.arange(\n                    v1_min, v1_max, (v1_max - v1_min) / 100, dtype=float\n                ):\n                    x.append(cur_v0)\n                    y.append(cur_v1)\n                    cur_guess[v0_idx] = round(cur_v0, 4)\n                    cur_guess[v1_idx] = round(cur_v1, 4)\n                    # numpy array are pointers so we do a deep copy here\n                    z.append(copy.deepcopy(cur_guess))\n            # predict z for the whole list\n            z = model.predict(\n                Scaler.transform(pd.DataFrame(z, columns=X_train.columns.to_list()))\n            )[:, target_idx]\n            # create plot\n            z = z.reshape(int(len(z) ** 0.5), int(len(z) ** 0.5))\n            fig = plt.figure()\n            plt.imshow(z, extent=(np.amin(x), np.amax(x), np.amin(y), np.amax(y)))\n            plt.colorbar()\n            plt.xlabel(combination[0])\n            plt.ylabel(combination[1])\n            single_plot_writer = MatplotlibDataset(\n                filepath=\"output/reporting/{}/2dMap_{}.png\".format(\n                    date.today(), \"\".join(combination)\n                )\n            )\n            plt.close()\n            single_plot_writer.save(fig)\n            logger.info(\"Saved 2dMap_{}.png.\".format(\"\".join(combination)))\n",
