  "code": "def set_timescaledb_data(\n    y_forecast: pd.DataFrame, parameters: dict[str, Any]\n) -> None:  # noqa: PLR0912\n    \"\"\"\n    Write forecast dataframe into TimescaleDB.\n\n    y_forecast:\n      - index: DatetimeIndex (future timestamps)\n      - columns: forecasted signals (metrics or column names)\n      - values: numeric forecast values\n\n    parameters[\"timescaledb\"] expected keys:\n      host, port(optional), user, password, database, machine\n\n    \"\"\"\n    logger = logging.getLogger(__name__)\n\n    # set back the index\n    y_forecast[\"ts\"] = pd.to_datetime(y_forecast[\"ts\"], utc=True, errors=\"raise\")\n    y_forecast = y_forecast.set_index(\"ts\")\n\n    source = \"kedro\"\n\n    if not isinstance(y_forecast, pd.DataFrame):\n        raise TypeError(\"y_forecast must be a pandas DataFrame.\")\n    if not isinstance(y_forecast.index, pd.DatetimeIndex):\n        raise TypeError(\"y_forecast.index must be a pandas DatetimeIndex.\")\n    if y_forecast.empty:\n        logger.info(\"y_forecast is empty, nothing to write.\")\n        return\n\n    # Ensure UTC timestamps (recommended for DB)\n    if y_forecast.index.tz is None:\n        # treat as UTC if naive; adjust here if you know it's local time\n        idx = y_forecast.index.tz_localize(\"UTC\")\n    else:\n        idx = y_forecast.index.tz_convert(\"UTC\")\n\n    y_forecast = y_forecast.copy()\n    y_forecast.index = idx\n\n    tsdb = parameters[\"timescaledb\"]\n    mach = tsdb[\"machine\"]\n\n    def flush(cur, conn, rows_buf):\n        if not rows_buf:\n            return 0\n\n        # Put forecast into `value`, mark `prediction` True\n        sql = \"\"\"\n            INSERT INTO measurements (ts, machine, source, metric, value, prediction)\n            VALUES %s\n            ON CONFLICT (ts, machine, metric) DO UPDATE\n            SET value = EXCLUDED.value,\n                prediction = COALESCE(EXCLUDED.prediction, measurements.prediction)\n        \"\"\"\n\n        execute_values(cur, sql, rows_buf, page_size=10000)\n        conn.commit()\n        n = len(rows_buf)\n        rows_buf.clear()\n        return n\n\n    # Connect\n    conn = psycopg2.connect(\n        host=tsdb[\"host\"],\n        port=tsdb.get(\"port\", 5432),\n        user=tsdb[\"user\"],\n        password=tsdb[\"password\"],\n        dbname=tsdb[\"database\"],\n    )\n    cur = conn.cursor()\n\n    try:\n        rows = []\n        total = 0\n\n        # Iterate timestamps and columns -> rows\n        for ts, row in y_forecast.iterrows():\n            # DB timestamp: timezone-aware datetime is fine for psycopg2\n            for col, val in row.items():\n                metric = col\n\n                # Skip NaNs / non-finite\n                try:\n                    fval = float(val)\n                    if not math.isfinite(fval):\n                        continue\n                except (TypeError, ValueError):\n                    continue\n\n                db_value = fval\n                db_pred = True\n\n                rows.append(\n                    (ts.to_pydatetime(), mach, source, metric, db_value, db_pred)\n                )\n\n                # Flush in chunks to avoid huge buffers\n                chunk_size = 10000\n                if len(rows) >= chunk_size:\n                    total += flush(cur, conn, rows)\n\n        total += flush(cur, conn, rows)\n        logger.info(\"Wrote %d forecast rows to TimescaleDB.\", total)\n\n    finally:\n        cur.close()\n        conn.close()\n",
