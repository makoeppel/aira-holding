  "code": "def get_timescaledb_data(\n    timescaledb_data: pd.DataFrame, parameters: dict[str, Any]\n) -> pd.DataFrame:\n    \"\"\"Transform timescaledb data from long format into wide format.\n\n    Args:\n        timescaledb_data: DataFrame containing time series metrics with columns\n            [\"ts\", \"machine\", \"metric\", \"value\", ...].\n        parameters:\n            machine: Machine identifier to filter on (e.g. \"toy12\").\n            metrics: List of metric names to include as columns (e.g. [\"NOx\", \"CO2\"]).\n            aggfunc: Aggregation method to resolve duplicates per (ts, metric).\n                Defaults to \"last\".\n\n    Returns:\n        pandas.DataFrame with one row per timestamp and one column per metric.\n        Example:\n            ts | NOx | CO2 | Throuput | Temeratur | ...\n    \"\"\"\n\n    # filter\n    machine = parameters[\"timescaledb\"][\"machine\"]\n    wanted_metrics = parameters[\"timescaledb\"][\"values\"]  # e.g. [\"NOx\",\"O2\",\"CO2\",...]\n\n    mask = (timescaledb_data[\"machine\"] == machine) & (\n        timescaledb_data[\"metric\"].isin(wanted_metrics)\n    )\n\n    df_filt = timescaledb_data.loc[mask, [\"ts\", \"metric\", \"value\"]].copy()\n\n    # If you can have multiple rows per (ts, metric), decide how to aggregate.\n    # Here we take the *mean* value per (ts, metric). You could use 'last', 'max', etc.\n    wide = (\n        df_filt.sort_values(\"ts\")\n        .pivot_table(\n            index=\"ts\",\n            columns=\"metric\",\n            values=\"value\",\n            aggfunc=parameters[\"timescaledb\"][\"aggfunc\"],\n        )\n        .reset_index()\n    )\n\n    return wide\n",
